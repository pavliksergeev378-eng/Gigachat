# Caddyfile — конфигурация локального HTTP-сервера для GigaChat.
# Запускается через GigaChat-Start.bat. Останавливается через GigaChat-Stop.bat
# (или закрытием окна caddy.exe в Taskbar).
#
# Адрес: http://localhost:8765
# Порт нестандартный, чтобы не конфликтовать с n8n (5678), стандартным HTTP (80),
# dev-серверами (3000/8000) и прочим. Если 8765 занят — поменять и тут, и в .bat.

:8765 {
	# Раздаём всё из папки, где лежит caddy.exe (корень проекта).
	root * .
	file_server
	encode gzip

	# При заходе на http://localhost:8765/ — сразу открываем дашборд.
	# Без этого правила пользователю пришлось бы вводить полный путь
	# /GigaChat-Platform.html в адресной строке.
	@root path /
	rewrite @root /GigaChat-Platform.html

	# Pyodide требует строгий Content-Type: application/wasm для .wasm файлов.
	# Без этого браузер ругается «failed to compile WebAssembly» и math-агент
	# не загружается. Дефолтный MIME у Caddy — octet-stream, что не подходит.
	@wasm path *.wasm
	header @wasm Content-Type application/wasm

	# python_stdlib.zip — Pyodide грузит его как ArrayBuffer. Дефолт Caddy
	# отдаёт application/zip, что обычно работает, но превентивно фиксируем
	# на octet-stream — если в офисе будет Caddy с кастомной MIME-таблицей
	# (например text/plain для .zip), Pyodide может не распарсить.
	@zip path *.zip
	header @zip Content-Type application/octet-stream

	# КЭШ: агенты (.html), дашборд и общий код (.js) НЕ кэшируем. Это корневой
	# фикс «обновил файлы в офисе, а в браузере всё по-старому»: после замены
	# файлов из свежего ZIP обычного обновления страницы достаточно — браузер
	# не отдаёт устаревшую копию, Ctrl+Shift+R больше не нужен.
	# Тяжёлые библиотеки (lib/* — pyodide, jszip, hljs), .wasm и .zip меняются
	# редко и остаются кэшируемыми, чтобы не перекачивать их каждый раз.
	@appcode {
		path / *.html *.js
		not path /Agents/lib/*
	}
	header @appcode Cache-Control "no-store, no-cache, must-revalidate"
	header @appcode Pragma "no-cache"
	header @appcode Expires "0"

	# В логах оставляем только ошибки — каждый ping раз в 30 сек заполнял бы
	# журнал, и было бы тяжело найти реальные проблемы.
	log {
		output stderr
		level ERROR
	}

	# Прокси healthz — решает CORS при проверке доступности n8n.
	# Браузер на http://8765 видит запрос к /n8n-healthz — same-origin,
	# CORS не нужен. Caddy проксирует на n8n /healthz.
	@healthz path /n8n-healthz
	reverse_proxy @healthz http://130.100.92.170:5678/healthz {
		header_up Host {upstream_hostport}
	}

	# CORS-заголовки для n8n webhook'ов (кросс-доменные запросы от chain-player
	# и Node Editor к n8n). Без них браузер блокирует POST из браузерного fetch.
	# Добавляем ко всем ответам, т.к. n8n сам не отдаёт Access-Control-Allow-*.
	header {
		Access-Control-Allow-Origin "*"
		Access-Control-Allow-Methods "GET, POST, PUT, DELETE, OPTIONS"
		Access-Control-Allow-Headers "Content-Type, X-Auth-Token"
	}
}

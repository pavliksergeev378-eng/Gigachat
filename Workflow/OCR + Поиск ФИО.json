      "id": "a1b2c3d4-0004-4000-8000-000000000004",
      "name": "OCR Распознавание",
      "alwaysOutputData": true,
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "jsCode": "// Извлекаем текст из ответа OCR.\n// Разные OCR-движки возвращают текст в разных полях.\ntry {\n  const data = $input.first().json;\n\n  // Если OCR вернул ошибку (onError: continueRegularOutput)\n  if (data.error) {\n    const msg = typeof data.error === 'string' ? data.error : (data.error.message || JSON.stringify(data.error));\n    return [{ json: { has_text: false, error: 'OCR ошибка: ' + msg } }];\n  }\n\n  let text = '';\n\n  // Пробуем типичные форматы ответа OCR\n  if (typeof data === 'string') {\n    text = data;\n  } else if (data.text && typeof data.text === 'string') {\n    text = data.text;\n  } else if (data.result && typeof data.result === 'string') {\n    text = data.result;\n  } else if (data.result && data.result.text) {\n    text = data.result.text;\n  } else if (data.content && typeof data.content === 'string') {\n    text = data.content;\n  } else if (data.data && typeof data.data === 'string') {\n    text = data.data;\n  } else if (data.output && typeof data.output === 'string') {\n    text = data.output;\n  } else {\n    // Последний шанс — весь ответ как строка\n    text = JSON.stringify(data);\n  }\n\n  text = text.trim();\n\n  if (!text || text === '{}' || text === '[]' || text === 'null' || text.length < 3) {\n    return [{ json: { has_text: false, error: 'OCR не смог распознать текст в документе. Попробуйте другой файл или более чёткий скан.' } }];\n  }\n\n  // Ограничиваем длину текста (GigaChat имеет лимит контекста)\n  if (text.length > 15000) {\n    text = text.substring(0, 15000) + '\\n[...текст обрезан — слишком длинный документ]';\n  }\n\n  return [{ json: { has_text: true, ocr_text: text } }];\n\n} catch (e) {\n  return [{ json: { has_text: false, error: 'Ошибка обработки ответа OCR: ' + e.message } }];\n}"
      },

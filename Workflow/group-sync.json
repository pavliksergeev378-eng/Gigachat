        "query": "WITH requester AS (\n  SELECT user_id FROM auth_sessions WHERE token = $3 AND expires_at > NOW()\n),\ncheck_role AS (\n  SELECT gm.role FROM group_members gm, requester r\n  WHERE gm.group_id = $1::integer AND gm.user_id = r.user_id\n),\nadmin_check AS (\n  SELECT is_admin FROM auth_users, requester r WHERE id = r.user_id\n)\nDELETE FROM group_members\nWHERE group_id = $1::integer AND user_id = $2::integer AND role <> 'manager'\n  AND (EXISTS (SELECT 1 FROM check_role WHERE role = 'manager')\n       OR EXISTS (SELECT 1 FROM admin_check WHERE is_admin = true))\nRETURNING group_id",

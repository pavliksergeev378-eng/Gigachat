        "jsCode": "const item = $input.first();\nconst data = item && item.json ? item.json : null;\nif (data && data.error) {\n  const msg = String(data.error.message || data.error);\n  if (/unique|duplicate|already exists/i.test(msg)) {\n    return [{ json: { response: 'error', error: 'Группа с таким названием уже существует' } }];\n  }\n  return [{ json: { response: 'error', error: msg } }];\n}\nif (!data || !data.group_id) {\n  return [{ json: { response: 'error', error: 'Не удалось создать группу' } }];\n}\nreturn [{ json: { response: 'ok', created: true, group_id: data.group_id } }];"

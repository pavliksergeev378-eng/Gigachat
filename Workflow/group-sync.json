    {
      "parameters": {
        "jsCode": "const body = $input.first().json.body || {};\nconst action = String(body.action || '').trim();\n\nconst ALLOWED = ['list_groups','my_group','join_group','create_group','leave_group','group_detail','add_member','remove_member'];\nif (!ALLOWED.includes(action)) {\n  return [{ json: { valid: 0, error: 'Неизвестный action: ' + action } }];\n}\n\nconst token = String(body.token || '').trim();\nif (!/^[a-f0-9]{64}$/.test(token)) {\n  return [{ json: { valid: 0, error: 'unauthorized', auth_required: true } }];\n}\n\nconst out = { valid: 1, action, token };\n\nif (action === 'create_group') {\n  const name = String(body.name || '').trim().slice(0, 200);\n  if (!name || name.length < 2) return [{ json: { valid: 0, error: 'Название группы обязательно (мин. 2 символа)' } }];\n  out.group_name = name;\n  out.group_desc = String(body.description || '').trim().slice(0, 1000);\n}\n\nif (action === 'join_group' || action === 'leave_group' || action === 'group_detail') {\n  const gid = parseInt(body.group_id, 10);\n  if (!gid || gid < 1) return [{ json: { valid: 0, error: 'group_id обязателен' } }];\n  out.group_id = gid;\n}\n\nif (action === 'add_member') {\n  const gid = parseInt(body.group_id, 10);\n  const uid = parseInt(body.user_id, 10);\n  if (!gid || gid < 1) return [{ json: { valid: 0, error: 'group_id обязателен' } }];\n  if (!uid || uid < 1) return [{ json: { valid: 0, error: 'user_id обязателен' } }];\n  out.group_id = gid;\n  out.target_user_id = uid;\n}\n\nif (action === 'remove_member') {\n  const gid = parseInt(body.group_id, 10);\n  const uid = parseInt(body.user_id, 10);\n  if (!gid || gid < 1) return [{ json: { valid: 0, error: 'group_id обязателен' } }];\n  if (!uid || uid < 1) return [{ json: { valid: 0, error: 'user_id обязателен' } }];\n  out.group_id = gid;\n  out.target_user_id = uid;\n}\n\nreturn [{ json: out }];"
      },
